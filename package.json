{
  "name": "tdcheetah",
  "version": "0.1.0",
  "description": "TdCheetah — A high-performance TDengine GUI management tool (Navicat-style), built with Electron + Vue 3 + TypeScript.",
  "main": "dist-electron/main.js",
  "author": {
    "name": "finalpi",
    "email": "46010917+finalpi@users.noreply.github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/finalpi/TdCheetah",
  "repository": {
    "type": "git",
    "url": "https://github.com/finalpi/TdCheetah.git"
  },
  "bugs": {
    "url": "https://github.com/finalpi/TdCheetah/issues"
  },
  "keywords": [
    "tdengine",
    "taos",
    "gui",
    "electron",
    "vue",
    "database",
    "time-series",
    "navicat"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "electron:build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "dayjs": "^1.11.13",
    "element-plus": "^2.9.1",
    "monaco-editor": "^0.52.2",
    "pinia": "^2.3.0",
    "uuid": "^11.0.3",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-store": "^8.2.0",
    "sass": "^1.83.0",
    "typescript": "^5.7.2",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^2.1.10"
  },
  "build": {
    "appId": "com.finalpi.tdcheetah",
    "productName": "TdCheetah",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "artifactName": "TdCheetah-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools",
      "artifactName": "TdCheetah-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb", "tar.gz"],
      "category": "Development",
      "artifactName": "TdCheetah-${version}-linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TdCheetah"
    }
  }
}
